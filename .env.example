# ─────────────────────────────────────────────────────────────
# TaskFlow — environment variables
# ─────────────────────────────────────────────────────────────
# Currently this app stores all data in browser localStorage,
# so no environment variables are required to run locally.
# This file exists so future contributors know which vars to set
# when integrating a real backend or third-party services.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical links, OG image base, etc.)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry DSN (optional, for error tracking in production)
# NEXT_PUBLIC_SENTRY_DSN=

# Vercel Analytics token (optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
